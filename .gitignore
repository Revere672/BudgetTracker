# ========================
# Gradle (backend)
# ========================
backend/.gradle/
backend/build/
backend/out/
!backend/gradle/wrapper/gradle-wrapper.jar
!backend/**/src/main/**/build/
!backend/**/src/test/**/build/

# ========================
# Angular (frontend)
# ========================
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/.sass-cache/

# ========================
# Docker
# ========================
# Don't ignore docker-compose.yml — you want that committed
# But never commit actual secrets (we'll address below)

# ========================
# IDE / Editor
# ========================
.idea/
*.iml
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# ========================
# OS
# ========================
.DS_Store
Thumbs.db
desktop.ini

# ========================
# Logs
# ========================
*.log
logs/

# ========================
# Secrets (important!)
# ========================
*.env
.env.*